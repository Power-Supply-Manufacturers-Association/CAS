{
    "description": "The description of a capacitor",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/cas/capacitor.json",
    "title": "capacitor",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "$ref": "#/$defs/manufacturerInfo"
        },
        "distributorsInfo": {
            "description": "Where to buy this component",
            "type": "array",
            "items": {
                "$ref": "https://psma.com/peas/utils.json#/$defs/distributorInfo"
            }
        },
        "capacitor": {
            "description": "Capacitor data wrapper (used by some DB entries)",
            "type": "object"
        }
    },
    "anyOf": [
        {
            "required": [
                "manufacturerInfo"
            ]
        },
        {
            "required": [
                "capacitor"
            ]
        },
        {
            "maxProperties": 0
        }
    ],
    "$defs": {
        "manufacturerInfo": {
            "title": "capacitorManufacturerInfo",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/name"
                },
                "reference": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/reference"
                },
                "status": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/status"
                },
                "description": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/description"
                },
                "orderCode": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/orderCode"
                },
                "datasheetUrl": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/datasheetUrl"
                },
                "spiceModel": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/spiceModel"
                },
                "family": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/family"
                },
                "datasheetInfo": {
                    "$ref": "#/$defs/datasheetInfo"
                }
            },
            "required": [
                "name",
                "datasheetInfo"
            ]
        },
        "datasheetInfo": {
            "title": "capacitorDatasheetInfo",
            "description": "Information extracted from the component datasheet and PMs Excel data",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "part": {
                    "description": "Basic part identification",
                    "$ref": "#/$defs/part"
                },
                "electrical": {
                    "description": "Electrical characteristics",
                    "$ref": "#/$defs/electrical"
                },
                "thermal": {
                    "description": "Thermal characteristics",
                    "$ref": "#/$defs/thermal"
                },
                "mechanical": {
                    "description": "Mechanical dimensions and shape information",
                    "$ref": "#/$defs/mechanical"
                },
                "lifetime": {
                    "description": "Lifetime parameters",
                    "$ref": "#/$defs/lifetime"
                },
                "modelParams": {
                    "description": "Model parameters for circuit simulation",
                    "$ref": "#/$defs/modelParams"
                },
                "factors": {
                    "description": "Derating factors for frequency and temperature",
                    "$ref": "#/$defs/factors"
                },
                "application": {
                    "description": "Manufacturer's recommended application / quality-grade categories, comma-joined as printed in the catalogue (e.g. Taiyo Yuden's grade taxonomy: 'Auto. (Powertrain/Safety)', 'Auto. (Body/Info) & High Reliability', 'Telecom-Infrastructure & Industrial', 'Medical (International Class. Ⅲ）', 'Medical (International Class. I ・ II)', 'General Equipment', 'Mobile Devices'). Free-form string — taxonomies are manufacturer-specific.",
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "part",
                "electrical",
                "mechanical"
            ]
        },
        "part": {
            "title": "capacitorPart",
            "description": "Basic part identification",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/datasheetInfoPartBase"
                },
                {
                    "type": "object",
                    "properties": {
                        "partNumber": {},
                        "series": {},
                        "case": {},
                        "description": {},
                        "technology": {
                            "description": "Capacitor technology / chemistry family. Closed enum so downstream selection logic can dispatch on chemistry without parsing free-form strings. Ceramic class is the dielectric-temperature behaviour family (class-1 = temperature-stable C0G/NP0; class-2 = X7R/X5R/Y5V high-K, voltage- and temperature-dependent; class-3 = Y5U etc.). The standard EIA/MIL dielectric code (e.g. X7R, C0G) goes in dielectricCode. thin-film-silicon is deposited SiO2/SiON dielectric on a substrate (Kyocera AVX Accu-P, Murata silicon capacitors, Vishay RFCS) - a distinct technology from sintered ceramics (different dielectric and process; distributors list it as its own category) and from the polymer film-* values. film-acrylic is the polymer-multi-layer (PML) construction: a vapour-deposited cross-linked acrylate (acrylic resin) dielectric stacked in 1000-5000 sub-micron layers (e.g. Rubycon PMLCAP) - distinct from wound/stacked thermoplastic metallized film (polypropylene/polyester/PPS) in both dielectric and process.",
                            "enum": [
                                "aluminum-electrolytic-wet",
                                "aluminum-electrolytic-polymer",
                                "aluminum-hybrid-polymer",
                                "tantalum-wet",
                                "tantalum-mno2",
                                "tantalum-polymer",
                                "niobium-oxide",
                                "ceramic-class-1",
                                "ceramic-class-2",
                                "ceramic-class-3",
                                "film-polypropylene",
                                "film-polyester",
                                "film-polyphenylene-sulfide",
                                "film-paper",
                                "film-acrylic",
                                "mica",
                                "thin-film-silicon",
                                "supercapacitor-edlc",
                                "supercapacitor-hybrid",
                                "vacuum"
                            ]
                        },
                        "dielectricCode": {
                            "description": "Standard EIA / MIL dielectric code (e.g. X7R, X5R, C0G, NP0, Y5V, Y5U). Applies to ceramic technologies only; null or absent for non-ceramic chemistries.",
                            "type": [
                                "string",
                                "null"
                            ]
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "technology"
                    ]
                }
            ]
        },
        "electrical": {
            "title": "capacitorElectrical",
            "description": "Electrical characteristics",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "capacitance": {
                    "description": "Capacitance value in Farads",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                },
                "capacitanceDriftLongTermPercent": {
                    "description": "End-of-life capacitance change in percent (decrease)",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "capacitanceMinimumLongTerm": {
                    "description": "Worst case of minimum capacitance (taking into account the tolerance) after end-of-life in Farads",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "capacitanceBiasPoints": {
                    "description": "Capacitance vs. DC-bias-voltage points (DC-bias derating curve, dominant for class-2 ceramics), each measured at a temperature and AC measurement voltage. voltage = DC bias in V, capacitance = effective capacitance in F at that bias.",
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                            "voltage": {
                                "description": "DC bias voltage in Volts.",
                                "type": "number"
                            },
                            "capacitance": {
                                "description": "Effective capacitance at this DC bias in Farads.",
                                "type": "number",
                                "minimum": 0
                            },
                            "temperature": {
                                "description": "Measurement temperature in degrees Celsius.",
                                "type": "number"
                            },
                            "acVoltage": {
                                "description": "AC measurement (signal) voltage in Volts.",
                                "type": "number"
                            }
                        },
                        "required": [
                            "voltage",
                            "capacitance"
                        ]
                    }
                },
                "ratedVoltage": {
                    "description": "Rated voltage in Volts",
                    "type": "number"
                },
                "polarized": {
                    "description": "True for polarized capacitors (aluminum electrolytic, tantalum, tantalum-polymer, niobium-oxide, supercapacitor-EDLC) that must see voltage of one fixed polarity only. False for ceramic, film, mica and other symmetric chemistries. Null when the librarian could not determine polarity from the datasheet — downstream selection logic should treat null as 'unknown, do not allow AC swing' (conservative).",
                    "type": [
                        "boolean",
                        "null"
                    ]
                },
                "voltageRatedDcMax": {
                    "description": "Maximum DC rated voltage in Volts",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "dissipationFactor": {
                    "description": "Dissipation factor (tan delta) as fraction (e.g. 0.025 = 2.5%)",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "dissipationFactorFrequency": {
                    "description": "Frequency at which the single-point dissipationFactor field above is measured, in Hz. Prefer dissipationFactorPoints for selection logic; this scalar pair is kept only for legacy datasheet values where no curve is available.",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "dissipationFactorPoints": {
                    "description": "Dissipation-factor-vs-frequency curve. xData = frequency in Hz, yData = tan delta as fraction (e.g. 0.025 for 2.5%). Same frequency-dependence motivation as esrPoints — DF and ESR are linked through DF = ESR * omega * C, so any chemistry whose ESR rises sharply at low frequency also shows a corresponding rise in DF. Selection logic must prefer this curve over the scalar dissipationFactor field when present.",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/curve"
                },
                "qFactor": {
                    "description": "Quality factor (dimensionless, Q = 1/tan delta) as specified on the datasheet — for class-1 (C0G/NP0) MLCCs this is the specified MINIMUM Q at the standard measurement condition (EIA-198 / IEC 60384: Q ≥ 1000 for C ≥ 30 pF, Q ≥ 400 + 20·C[pF] below 30 pF, measured at 1 MHz, 1 Vrms). Q is strongly frequency-dependent, so pair this scalar with qFactorFrequency when the measurement frequency is known; absent qFactorFrequency means 'datasheet minimum at the manufacturer's standard condition', not a broadband value.",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "qFactorFrequency": {
                    "description": "Frequency at which the qFactor field above is specified, in Hz. Null or absent when the datasheet states only the standard-condition minimum without an explicit frequency.",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "leakageCurrent": {
                    "description": "Leakage current in Amperes",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "insulationResistance": {
                    "description": "Insulation resistance in Ohms",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "esr": {
                    "description": "Equivalent series resistance (ESR) in Ohms",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "esrFrequency": {
                    "description": "Frequency at which the single-point esr field above is measured, in Hz. Prefer esrPoints for selection logic; this scalar pair is kept only for legacy datasheet values where no curve is available.",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "esrPoints": {
                    "description": "ESR-vs-frequency curve. xData = frequency in Hz, yData = ESR in Ohms. Captures the strong frequency dependence of ESR for class-2 ceramic and polymer chemistries — at low frequency (sub-kHz, e.g. 50/60 Hz mains) ESR can be one to two orders of magnitude larger than its 100 kHz datasheet value (see https://passive-components.eu/esr-of-capacitors-mechanisms-measurements-and-impact-to-applications/ Fig. 4). Selection logic must prefer this curve over the scalar esr field when present.",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/curve"
                },
                "rippleCurrent": {
                    "description": "Ripple current in Amperes",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "rippleCurrentFrequency": {
                    "description": "Frequency at which ripple current is specified in Hz",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "rippleCurrentTemperature": {
                    "description": "Temperature at which ripple current is specified in °C",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "rippleCurrentFrequencyPoints": {
                    "description": "Ripple current derating curve as a function of frequency",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/curve"
                },
                "rippleCurrentTemperaturePoints": {
                    "description": "Ripple current derating curve as a function of temperature",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/curve"
                },
                "thermalResistance": {
                    "description": "Thermal resistance in °C/W",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "_esrWarning": {
                    "description": "Internal flag or message: ESR value estimated or extrapolated (not from datasheet). True/false flag or descriptive warning string.",
                    "type": [
                        "boolean",
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "capacitance",
                "ratedVoltage"
            ]
        },
        "thermal": {
            "title": "capacitorThermal",
            "description": "Thermal characteristics — extends PEAS datasheetInfoThermal with capacitance-temperature coefficient.",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/datasheetInfoThermal"
                },
                {
                    "type": "object",
                    "properties": {
                        "operatingTemperature": {},
                        "temperature": {},
                        "tcc": {
                            "description": "Capacitance change over temperature range",
                            "oneOf": [
                                {
                                    "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "mechanical": {
            "title": "capacitorMechanical",
            "description": "Mechanical dimensions and shape information",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "dimensions": {
                    "description": "Physical dimensions of the component",
                    "$ref": "#/$defs/dimensions"
                },
                "shape": {
                    "description": "Component shape and assembly information",
                    "$ref": "#/$defs/shape"
                }
            },
            "required": [
                "shape"
            ]
        },
        "dimensions": {
            "title": "capacitorDimensions",
            "description": "Physical dimensions of the component",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "diameter": {
                    "description": "Diameter in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "width": {
                    "description": "Width / A dimension in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "length": {
                    "description": "Length / B dimension in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "height": {
                    "description": "Height dimension in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "thickness": {
                    "description": "Thickness / T dimension in meters. Chip-style (MLCC) datasheets specify the body as L × W × T, where T is the dimension perpendicular to the mounting plane; unlike the EIA case code (which fixes only L × W), T varies per part with layer count. Kept separate from height to stay faithful to datasheet nomenclature.",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "pitch": {
                    "description": "Pin pitch spacing in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "pinDiameter": {
                    "description": "Pin diameter in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "pinLength": {
                    "description": "Pin length in meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            },
            "required": []
        },
        "shape": {
            "title": "capacitorShape",
            "description": "Component shape and assembly information",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "assembly": {
                    "description": "Assembly type",
                    "type": "string",
                    "enum": [
                        "THT",
                        "Screw Type",
                        "SMT",
                        "Snap-In"
                    ]
                },
                "shapeType": {
                    "description": "Shape type",
                    "type": "string"
                },
                "volume": {
                    "description": "Component volume in cubic meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "footprint": {
                    "description": "PCB footprint area in square meters",
                    "oneOf": [
                        {
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            },
            "required": [
                "assembly",
                "shapeType"
            ]
        },
        "lifetime": {
            "title": "capacitorLifetime",
            "description": "Reliability and lifetime parameters — extends PEAS datasheetInfoLifetime with capacitor-specific end-of-life definitions.",
            "allOf": [
                {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/datasheetInfoLifetime"
                },
                {
                    "type": "object",
                    "properties": {
                        "maxLifetime": {},
                        "kfactor": {},
                        "bexp": {},
                        "vxfactor": {},
                        "usefulLife": {},
                        "deltaT0": {},
                        "aexp": {},
                        "lifetimeEndurance": {},
                        "endDefinitionC": {
                            "description": "End-of-life capacitance change in percent (decrease)",
                            "type": [
                                "number",
                                "null"
                            ]
                        },
                        "endDefinitionEsr": {
                            "description": "End-of-life ESR change in percent (increase)",
                            "type": [
                                "number",
                                "null"
                            ]
                        },
                        "eoUsefulLifeC": {
                            "description": "End-of-useful-life capacitance change in percent (decrease)",
                            "type": [
                                "number",
                                "null"
                            ]
                        },
                        "eoUsefulLifeR": {
                            "description": "End-of-useful-life resistance change in percent (increase)",
                            "type": [
                                "number",
                                "null"
                            ]
                        },
                        "usefulLifeComment": {
                            "description": "Additional comments about useful life",
                            "type": [
                                "string",
                                "null"
                            ]
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "modelParams": {
            "title": "capacitorModelParams",
            "description": "Circuit model parameters for SPICE simulation",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "rs": {
                    "description": "Series resistance in Ohms",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "cs": {
                    "description": "Series capacitance in Farads",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "ls": {
                    "description": "Series inductance in Henries",
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "riso": {
                    "description": "Isolation resistance in Ohms",
                    "type": [
                        "number",
                        "null"
                    ]
                }
            },
            "required": []
        },
        "factors": {
            "title": "capacitorFactors",
            "description": "Derating factors as functions of frequency and temperature",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "rippleCurrentFrequencyFactorFrequency": {
                    "description": "Frequency values for ripple current derating curve",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/numberArray"
                },
                "rippleCurrentFrequencyFactorAmplitude": {
                    "description": "Derating factors at specified frequencies",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/numberArray"
                },
                "rippleCurrentTemperatureFactorTemperature": {
                    "description": "Temperature values for ripple current derating curve",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/numberArray"
                },
                "rippleCurrentTemperatureFactorAmplitude": {
                    "description": "Derating factors at specified temperatures",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/numberArray"
                }
            },
            "required": []
        }
    }
}
