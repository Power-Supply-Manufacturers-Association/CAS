{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/CAS/inputs/designRequirements.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "designRequirements",
    "description": "The list of requirements that a given capacitor must comply with. Built on top of the EAS designRequirementsBase mixin (shared name/market/topology/operatingTemperature/terminalType/maximumWeight/maximumDimensions) plus capacitor-specific fields and a narrowed role/allowedTechnologies enum.",
    "allOf": [
        {
            "$ref": "../../../EAS/schemas/utils.json#/$defs/designRequirementsBase"
        },
        {
            "type": "object",
            "properties": {
                "capacitance": {
                    "description": "Required values for the capacitance, in F",
                    "$ref": "../../../EAS/schemas/utils.json#/$defs/dimensionWithTolerance"
                },
                "ratedVoltage": {
                    "description": "Minimum required rated DC voltage, in V",
                    "type": "number",
                    "minimum": 0
                },
                "maximumEsr": {
                    "description": "Maximum allowed equivalent series resistance, in Ohm",
                    "type": "number",
                    "minimum": 0
                },
                "minimumRippleCurrent": {
                    "description": "Minimum required rated ripple current, in A RMS",
                    "type": "number",
                    "minimum": 0
                },
                "minimumLifetime": {
                    "description": "Minimum required lifetime under the declared operating points, in hours",
                    "type": "number",
                    "minimum": 0
                },
                "role": {
                    "description": "Capacitor role in the converter. Used together with 'topology' to pick the correct stress and lifetime model.",
                    "type": "string",
                    "enum": [
                        "dcLink",
                        "decoupling",
                        "outputFilter",
                        "inputFilter",
                        "snubber",
                        "resonant",
                        "bootstrap",
                        "holdUp"
                    ]
                },
                "application": {
                    "$ref": "../../../EAS/schemas/utils.json#/$defs/capacitorApplication"
                },
                "subApplication": {
                    "$ref": "../../../EAS/schemas/utils.json#/$defs/capacitorSubApplication"
                },
                "allowedTechnologies": {
                    "description": "Subset of capacitor technologies acceptable for this design. If absent, all technologies are allowed.",
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "MLCC Class I",
                            "MLCC Class II",
                            "Alum. Electrolytic",
                            "Alum. Polymer",
                            "Hybrid Polymer",
                            "Film Capacitor"
                        ]
                    },
                    "minItems": 1,
                    "uniqueItems": true
                }
            },
            "required": [
                "capacitance",
                "ratedVoltage"
            ]
        }
    ],
    "$defs": {}
}
