{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/CAS/inputs.json",
    "$comment": "SPDX-License-Identifier: Apache-2.0",
    "title": "inputs",
    "description": "The description of the inputs that can be used to design or evaluate a Capacitor. Mirrors the MAS inputs structure (operatingPoints[] + designRequirements), with single-element excitation per operating point because a capacitor is two-terminal.",
    "type": "object",
    "properties": {
        "operatingPoints": {
            "description": "Data describing the operating points",
            "title": "operatingPoints",
            "type": "array",
            "items": {
                "$ref": "../../EAS/schemas/inputs/twoTerminalOperatingPoint.json"
            },
            "minItems": 1
        },
        "designRequirements": {
            "description": "Data describing the design requirements",
            "title": "designRequirements",
            "$ref": "./inputs/designRequirements.json"
        }
    },
    "required": [
        "operatingPoints",
        "designRequirements"
    ],
    "$defs": {}
}
